{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "italian",
  "cleanupPeriodDays": 14,
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(node run_migrations.js)",
      "Bash(npx supabase:*)"
    ]
  }
}
